# =============================================
# EpiConecta — Template de Variáveis de Ambiente
# Copie para .env e preencha os valores reais
# =============================================

PORT=3001
NODE_ENV=development

JWT_ACCESS_SECRET=<gere_com_node_crypto_randomBytes_64>
JWT_REFRESH_SECRET=<gere_com_node_crypto_randomBytes_64>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

DB_PATH=./data/epiconecta.db

AES_SECRET=<gere_com_node_crypto_randomBytes_32>

ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

ADMIN_NAME=Administrador
ADMIN_CPF=000.000.000-00
ADMIN_PASSWORD=<senha_forte>
